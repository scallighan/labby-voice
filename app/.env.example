# Running environment
RUNNING_ON_AZURE=0

# Identity (from Terraform: azurerm_user_assigned_identity.bot)
TENANT_ID=
CLIENT_ID=

# M365 Agent SDK connection
CONNECTIONS__SERVICE_CONNECTION__SETTINGS__TENANTID=
CONNECTIONS__SERVICE_CONNECTION__SETTINGS__CLIENTID=
CONNECTIONS__SERVICE_CONNECTION__SETTINGS__AUTHTYPE=UserManagedIdentity

# Azure AI Foundry
AZURE_AI_PROJECT_ENDPOINT=
FOUNDRY_MODEL=gpt-5.4-mini

# Azure AI Search
AZURE_SEARCH_ENDPOINT=
SEARCH_KNOWLEDGE_BASE_NAME=

# Azure AI Speech (Voice Live API) — auth via Managed Identity, no key needed
AZURE_SPEECH_REGION=eastus

# Azure Communication Services
ACS_CONNECTION_STRING=

# Azure subscription for Resource Graph queries
AZURE_SUBSCRIPTION_ID=

# Server
PORT=3978
